---
title: GMIP — LangGraph Intelligence Pipeline
---

graph TD
    START((Start)) --> SUP

    SUP{Supervisor<br/>deterministic routing}

    SUP -- "no data yet" --> COLL
    SUP -- "data collected" --> ANAL
    SUP -- "analysis done" --> DISS
    SUP -- "final response exists" --> END_NODE((End))

    COLL[Collection Node<br/>deterministic: query parsing +<br/>country/asset mappings]
    ANAL[Analysis Node<br/>deterministic: correlations,<br/>patterns, anomalies]
    DISS[Dissemination Node<br/>Llama 3 via Ollama<br/>only LLM call in pipeline]

    COLL -- "updates state" --> SUP
    ANAL -- "updates state" --> SUP
    DISS -- "updates state" --> SUP

    STATE[/AgentState<br/>query + collected_data +<br/>analysis_results + final_response/]

    COLL -. "reads & writes" .-> STATE
    ANAL -. "reads & writes" .-> STATE
    DISS -. "reads & writes" .-> STATE

    classDef sup fill:#f59e0b,stroke:#d97706,color:#000
    classDef determ fill:#059669,stroke:#047857,color:#fff
    classDef llm fill:#7c3aed,stroke:#6d28d9,color:#fff
    classDef state fill:#1e293b,stroke:#334155,color:#e2e8f0
    classDef endpoint fill:#ef4444,stroke:#dc2626,color:#fff

    class SUP sup
    class COLL,ANAL determ
    class DISS llm
    class STATE state
    class START,END_NODE endpoint
