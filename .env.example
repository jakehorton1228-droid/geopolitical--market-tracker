# Database (matches docker-compose.yml defaults)
DATABASE_URL=postgresql://postgres:postgres@db:5432/geopolitical_tracker

# LLM (Ollama runs NATIVELY on the host for Metal GPU acceleration on Apple Silicon)
# Docker containers reach it via host.docker.internal
# Alternatives: gemma4:e4b (faster, ~10GB), gemma4:31b (flagship, ~20GB)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma4:26b

# LangSmith (LLM observability — optional, set to true to enable tracing)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGCHAIN_PROJECT=gmip-intelligence-pipeline
